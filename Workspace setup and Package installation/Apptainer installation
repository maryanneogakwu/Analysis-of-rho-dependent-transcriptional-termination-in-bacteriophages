#Apptainer is a linux container platform optimized for High Performance Computing (HPC) AND Enterprise Performance Computing (HPC). Apptainer containers provide an application virtualizationlayer enabling mobility of compute via both application and environmant portability. 

#Pre built packages of Apptainer installed on Ubuntu system v 22.04 using sudo command

#!/bin/bash

sudo apt install -y software-properties-common
sudo add-apt-repository -y ppa:apptainer/ppa
sudo apt update
sudo apt install -y apptainer

apptainer --version 
#apptainer version 1.5.0

######################## BATTER INSTALLATION ####################
#Pulling the docker container image for BATTER
apptainer pull batter.sif docker://jinyf1998/batter:v0.0

#Setting the path to BATTER as a variable, and adding the path to bash file to make the vairiable permanent and available in the Apptainer program and allows it to run every time the terminal is opened

BATTER=/home/oc/binf_6999_2026/batter.sif
nano ~/.bashrc
export PATH=$PATH:/usr/bin
export BATTER=/home/oc/binf_6999_2026/batter.sif

source ~/.bashrc
echo $BATTER

cd /home/oc/binf_6999_2026/
#Cloning the batter repository, as the sc
git clone https://github.com/lulab/BATTER
cd BATTER
apptainer exec --nv -B $(pwd) $BATTER /bin/bash -c "source activate batter-env && scripts/batter-tpe --help"


#Testing the software with the example data provided
apptainer exec --nv -B $(pwd) $BATTER /bin/bash -c "source activate batter-env && scripts/batter-tpe --fasta examples/e.coli/genome.fna --output examples/e.coli/TPE.bed --device cpu"

# Running BATTER on phage data 
apptainer exec batter_latest.sif batter --input sequences.fa --output results/
OR
# sif is the path of image
apptainer exec --nv -B $(pwd) batter.sif /bin/bash
conda activate batter-env
OR
# Run batter-tpe
apptainer exec --nv -B $(pwd) $BATTER /bin/bash -c "source activate batter-env && scripts/batter-tpe --fasta your_genome.fna --output output.bed --device cpu"

# Run batter-rut
apptainer exec --nv -B $(pwd) $BATTER /bin/bash -c "source activate batter-env && scripts/batter-rut -i your_genome.fna -ivs your_tpe.bed --output output.bed"


##################################### RHOTERMPREDICT INSTALLATION #######################################
#Pulling the rhotermpredict image
apptainer pull /scratch/mogakwu/binf_6999_2026/rhotermpredict.sif docker://quay.io/biocontainers/rhotermpredict:3.4--pyh7e72e81_0


########################## BACTERMFINDER INSTALLATION #####################
#BacTermFinder doesn't have a pre-built image so it will be installed and rn in a virtual environment 
#Clone the repo
cd binf_6999_2026
git clone https://github.com/BioinformaticsLabAtMUN/BacTermFinder

# Load Python
module load StdEnv/2023
module load python/3.11.5

# Create a virtual environment
cd BacTermFinder
python -m venv bactermfinder-env
source bactermfinder-env/bin/activate

#Install dependencies
pip install numpy
pip install -r requirements.txt
#grpcio==1.47.0 not available on Nibi as only never versions are, so the available vrsions were downlaoded
pip install grpcio==1.51.1
#Installing the rest of the requirements ignoring grpcio
pip install -r requirements.txt --ignore-installed grpcio

export BACTERMFINDER=/scratch/mogakwu/binf_6999_2026/BacTermFinder


#COMEBACK TO THIS LATER FOR OTHER PACKAGES
#Storing the container paths in the bash.rc file
export BATTER=/home/oc/binf_6999_2026/batter.sif
export RHOTERM=/home/oc/binf_6999_2026/rhoterm.sif




