Data of phage genome sequences obtained from Genbank nucleotide using NCBI E-utilities efetch

SLURM Script
#!/bin/bash
#SBATCH --account=def-cottenie
#SBATCH --job-name=download_phages
#SBATCH --time=02:00:00
#SBATCH --mem=4G
#SBATCH --cpus-per-task=1
#SBATCH --output=/scratch/mogakwu/binf_6999_2026/phages/logs/download_%j.out
#SBATCH --error=/scratch/mogakwu/binf_6999_2026/phages/logs/download_%j.err

#Load NCBI E-utilities
module load StdEnv/2023
module load edirect/20.9.20231210

#Paths and Output directory
OUTDIR=/scratch/mogakwu/binf_6999_2026/phages
SAMPLES=/scratch/mogakwu/binf_6999_2026/phages/samples.txt
mkdir -p $OUTDIR


#Tracking download progress
FAILED=()
SUCCESS=0

#Download loop
while read ACCESSION NAME; do
    OUTFILE=$OUTDIR/${ACCESSION}_${NAME}.fasta

    #Condition to skip if already downloaded
    if [[ -f "$OUTFILE" && -s "$OUTFILE" ]]; then
        echo "[SKIP] $ACCESSION ($NAME) already exists"
        continue
    fi

    echo "[DOWNLOADING] $ACCESSION - $NAME ..."

    #Download from NCBI
    efetch -db nucleotide -id "$ACCESSION" -format fasta > "$OUTFILE" 2>/dev/null

    #Check success of download
    if [[ $? -eq 0 && -s "$OUTFILE" ]]; then
        echo "[SUCCESS] $ACCESSION ($NAME) downloaded successfully"
        ((SUCCESS++))
    else
        echo "[ERROR] Failed to download $ACCESSION ($NAME)"
        rm -f "$OUTFILE"
        FAILED+=("$ACCESSION ($NAME)")
    fi

    #Pause between samples to respect NCBI rate limits
    sleep 1

done < $SAMPLES

#Final summary
echo ""
echo "==============================="
echo "Download Summary"
echo "==============================="
echo "Successfully downloaded: $SUCCESS"
echo "Failed: ${#FAILED[@]}"

if [[ ${#FAILED[@]} -gt 0 ]]; then
    echo ""
    echo "Failed accessions:"
    for FAIL in "${FAILED[@]}"; do
        echo "  - $FAIL"
    done
fi

sbatch download_phages.sh
