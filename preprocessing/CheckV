module load StdEnv/2023
module load apptainer/1.4.5
apptainer pull /scratch/mogakwu/binf_6999_2026/checkv.sif docker://quay.io/biocontainers/checkv:1.0.1--pyhdfd78af_0

#Bashrc file
nano ~/.bashrc
module load StdEnv/2023
module load apptainer/1.4.5
export CHECKV=/scratch/mogakwu/binf_6999_2026/checkv.sif
export CHECKVDB=/scratch/mogakwu/binf_6999_2026/checkv_db/checkv-db-v1.2
source ~/.bashrc

#Downloading the database
wget https://portal.nersc.gov/CheckV/checkv-db-v1.2.tar.gz
tar -xzvf checkv-db-v1.2.tar.gz

#Building the DIAMOND database because it is built locally after download as this saves download size 
apptainer exec $CHECKV diamond makedb \
    --in /scratch/mogakwu/binf_6999_2026/checkv_db/checkv-db-v1.2/genome_db/checkv_reps.faa \
    --db /scratch/mogakwu/binf_6999_2026/checkv_db/checkv-db-v1.2/genome_db/checkv_reps

#Testing the checkv database on just one sample
apptainer exec $CHECKV checkv end_to_end \
    /scratch/mogakwu/binf_6999_2026/phages/AF246223_Mycoplasma_phage_P1.fasta \
    /scratch/mogakwu/binf_6999_2026/practice/checkv_test \
    -d $CHECKVDB \
    -t 4

#Load apptainer
module load StdEnv/2023
module load apptainer/1.4.5

#Paths
BASEDIR=/scratch/mogakwu/binf_6999_2026
CHECKV=$BASEDIR/checkv.sif
CHECKVDB=$BASEDIR/checkv_db/checkv-db-v1.2
PHAGE_DIR=$BASEDIR/phages
OUTDIR=$BASEDIR/checkv_results
mkdir -p $OUTDIR

#Get the sample for this array task
FASTA=$(ls $PHAGE_DIR/*.fasta | sed -n "${SLURM_ARRAY_TASK_ID}p")
SAMPLE=$(basename $FASTA .fasta)

echo "[START] Running CheckV on $SAMPLE"

#Run CheckV
apptainer exec $CHECKV checkv end_to_end \
    $FASTA \
    $OUTDIR/${SAMPLE} \
    -d $CHECKVDB \
    -t 4

#Check success
if [[ $? -eq 0 ]]; then
    echo "[SUCCESS] CheckV completed for $SAMPLE"
else
    echo "[ERROR] CheckV failed for $SAMPLE"
    exit 1
fi

echo "[DONE] $SAMPLE finished"
