BactermFinder could not be installed through apptainer on the Nibi cluster so analysis was run there browser page provided by authors:
https://bactermfinder-tfjs.vercel.app/

Based on the the sliding window that bactermfinder uses to check through the sequences, it produces multiple predicted windows with extreme overlaps, so it is necessary to merge the similar overlaps. The python script to merge the outputs is below:

# Merge overlapping BacTermFinder predictions into single sites
# Input: bactermfinder_new_results
# Output: bactermfinder_merged_v2

import os
import csv
import glob

# Paths
BACTERMFINDER_DIR = "/scratch/mogakwu/binf_6999_2026/bactermfinder_new_results/"
MERGED_DIR = "/scratch/mogakwu/binf_6999_2026/bactermfinder_merged_v2/"
os.makedirs(MERGED_DIR, exist_ok=True)

# Gap threshold — windows within 50 bp of each other get merged
GAP = 50

def merge_overlapping_predictions(filepath):
    """Merge overlapping BacTermFinder windows into single representative sites"""

    results = []

    # Read predictions
    with open(filepath) as f:
        reader = csv.DictReader(f)
        rows = list(reader)

    if len(rows) == 0:
        return results

    # Print column names for debugging
    if rows:
        print(f"  Columns found: {list(rows[0].keys())}")

    # Process each strand separately
    for strand in ["+", "-"]:
        strand_rows = [r for r in rows if r["strand"] == strand]

        if len(strand_rows) == 0:
            continue

        # Sort by start position
        strand_rows.sort(key=lambda x: int(x["start"]))

        # Greedy merging
        merged_start = int(strand_rows[0]["start"])
        merged_end = int(strand_rows[0]["end"])
        merged_score = float(strand_rows[0]["average"])
        merged_count = 1

        for i in range(1, len(strand_rows)):
            current_start = int(strand_rows[i]["start"])
            current_end = int(strand_rows[i]["end"])
            current_score = float(strand_rows[i]["average"])

            # If this window overlaps or is within gap distance
            if current_start <= merged_end + GAP:
                merged_end = max(merged_end, current_end)
                merged_score = max(merged_score, current_score)
                merged_count += 1
            else:
                results.append({
                    "start": merged_start,
                    "end": merged_end,
                    "strand": strand,
                    "average": merged_score,
                    "window_count": merged_count
                })
                merged_start = current_start
                merged_end = current_end
                merged_score = current_score
                merged_count = 1

        # Save last merged region
        results.append({
            "start": merged_start,
            "end": merged_end,
            "strand": strand,
            "average": merged_score,
            "window_count": merged_count
        })

    return results

# ============================================================
# Check input directory exists and has files
# ============================================================
if not os.path.exists(BACTERMFINDER_DIR):
    print(f"[ERROR] Input directory not found: {BACTERMFINDER_DIR}")
    exit(1)

files = glob.glob(f"{BACTERMFINDER_DIR}*.csv")

if len(files) == 0:
    print(f"[ERROR] No CSV files found in {BACTERMFINDER_DIR}")
    print(f"Files present: {os.listdir(BACTERMFINDER_DIR)}")
    exit(1)

print(f"[INFO] Found {len(files)} files to process\n")

# ============================================================
# Process all BacTermFinder files
# ============================================================
summary_rows = []

for f in sorted(files):
    sample = os.path.basename(f).replace(".csv", "")
    short = sample.split("_phage_")[-1] if "_phage_" in sample else sample

    # Count lines before merging
    with open(f) as fh:
        before_count = sum(1 for _ in fh) - 1  # subtract header

    print(f"[START] {short} — {before_count} raw predictions")

    merged = merge_overlapping_predictions(f)
    after_count = len(merged)

    reduction = round((1 - after_count / before_count) * 100, 1) if before_count > 0 else 0

    # Write merged predictions
    outfile = f"{MERGED_DIR}{sample}_merged.csv"
    with open(outfile, "w", newline="") as out:
        writer = csv.DictWriter(out, fieldnames=["start", "end", "strand",
                                                  "average", "window_count"])
        writer.writeheader()
        writer.writerows(merged)

    summary_rows.append({
        "sample": short,
        "before": before_count,
        "after": after_count,
        "reduction_pct": reduction
    })

    print(f"[DONE] {short} — {before_count} → {after_count} predictions "
          f"({reduction}% reduction)\n")

# ============================================================
# Print overall summary
# ============================================================
print("===============================")
print("Merging Summary")
print("===============================")
total_before = sum(r["before"] for r in summary_rows)
total_after = sum(r["after"] for r in summary_rows)
overall_reduction = round((1 - total_after / total_before) * 100, 1) if total_before > 0 else 0

print(f"Files processed:       {len(summary_rows)}")
print(f"Total before merging:  {total_before}")
print(f"Total after merging:   {total_after}")
print(f"Overall reduction:     {overall_reduction}%")
print(f"\nMerged files saved to: {MERGED_DIR}")

After merging, the results will be filtered to get the highest confidence predictions
